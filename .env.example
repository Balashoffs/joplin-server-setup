# Joplin Server
# Перед первым деплоем сверьтесь с актуальным стабильным тегом:
# https://hub.docker.com/r/joplin/server/tags
JOPLIN_VERSION=3.6.1
# Базовый URL, под которым Joplin виден извне. Используется для генерации
# ссылок и валидации Origin/Host. Пустое значение — Joplin подставит
# http://localhost:22300, и сборка ссылок/синхронизация сломаются.
APP_BASE_URL=https://example.com

# Joplin Server при старте проверяет дрейф системных часов через NTP.
# Многие VPS-провайдеры режут исходящий UDP/123 на pool.ntp.org — без рабочего
# NTP контейнер уйдёт в restart-loop. Укажите тот NTP, что использует chrony
# на хосте (см. /etc/chrony/chrony.conf или `chronyc sources`).
NTP_SERVER=ntp.hostkey.ru:123

# PostgreSQL
POSTGRES_USER=joplin
# POSTGRES_PASSWORD генерируется deploy.sh при первом запуске
# (openssl rand -base64 24). Заглушка ниже не используется напрямую.
POSTGRES_PASSWORD=__GENERATED_BY_DEPLOY_SH__
POSTGRES_DB=joplin
